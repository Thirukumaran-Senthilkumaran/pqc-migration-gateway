# Copy to .env for local development.

# --- UI -> API ---
# Where the dashboard finds the API. Use 127.0.0.1 locally (never 0.0.0.0 / LAN IP).
API_BASE_URL=http://127.0.0.1:8000

# --- API (prefix PQCG_) ---
PQCG_SECRET_KEY=change-me-to-a-long-random-string
PQCG_CORS_ORIGINS=*

# PQC engine: auto | demo | liboqs
PQCG_PQC_BACKEND=auto

# Optional: real AI advisor (otherwise rule-based)
# PQCG_OPENAI_API_KEY=sk-...

# Set automatically on Render; override locally if needed:
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
