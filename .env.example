# Copy to `.env` to override defaults. All variables are optional.

# Web/API server
PQCG_HOST=0.0.0.0
PQCG_PORT=8080

# Discovery
PQCG_DISCOVERY_INTERVAL_SEC=60
# PQCG_DISCOVERY_SUBNET=192.168.1.0/24
# Force a specific NIC name (Windows: 'Wi-Fi', 'Ethernet'; Linux: 'eth0', 'wlan0'):
# PQCG_DISCOVERY_INTERFACE=Wi-Fi

# PQC backend (auto-detect by default)
# PQCG_BACKEND=liboqs   # liboqs | pqcrypto | demo
PQCG_HYBRID_CLASSICAL=true

# Gateway listeners
PQCG_GATEWAY_LISTEN_BASE_PORT=18000
PQCG_GATEWAY_MAX_SESSIONS=1024

# Security
# Generate something random in production:
#   python -c "import secrets;print(secrets.token_urlsafe(48))"
# PQCG_SECRET_KEY=
